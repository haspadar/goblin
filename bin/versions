#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Goblin\Cli\Arguments;
use Goblin\Cli\Command\VersionsCommand;
use Goblin\Config\ConfigFile;
use Goblin\Config\FileConfig;
use Goblin\Git\ShellGit;
use Goblin\GoblinException;
use Goblin\Http\CurlHttp;
use Goblin\Issue\ProjectKey;
use Goblin\Output\JsonOutput;
use Goblin\Output\PrefixedOutput;
use Goblin\Output\TextOutput;

$options = [];
$positionals = [];
$parsingOptions = true;

foreach (array_slice($argv, 1) as $arg) {
    if ($parsingOptions && $arg === '--') {
        $parsingOptions = false;

        continue;
    }

    if ($parsingOptions && str_starts_with($arg, '--')) {
        $parts = explode('=', substr($arg, 2), 2);
        $options[$parts[0]] = $parts[1] ?? true;
    } else {
        $positionals[] = $arg;
    }
}

$isTty = function_exists('stream_isatty')
    ? stream_isatty(STDOUT)
    : (function_exists('posix_isatty') && posix_isatty(STDOUT));

$output = new PrefixedOutput(
    'versions: ',
    $isTty ? new TextOutput() : new JsonOutput(),
);

$args = new Arguments($options, $positionals);
$code = 1;

try {
    $configPath = dirname(__DIR__) . '/.goblin.php';
    $config = new FileConfig((new ConfigFile($configPath))->data());

    $http = new CurlHttp(
        $config->value('jira-url'),
        $config->value('jira-user'),
        $config->value('jira-token'),
    );

    $git = new ShellGit();
    $project = new ProjectKey($args->positional(0), $git, $config);

    $code = (new VersionsCommand($http, $project, $output))
        ->run($args);
} catch (GoblinException $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    $code = 1;
}

exit($code);
