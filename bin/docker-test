#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Goblin\Cli\Arguments;
use Goblin\Cli\Command\TestCommand;
use Goblin\Config\ConfigFile;
use Goblin\Config\FileConfig;
use Goblin\Docker\ShellDocker;
use Goblin\GoblinException;
use Goblin\Output\PrefixedOutput;
use Goblin\Output\TextOutput;

$options = [];
$positionals = [];

foreach (array_slice($argv, 1) as $arg) {
    if (str_starts_with($arg, '--')) {
        $parts = explode('=', substr($arg, 2), 2);
        $options[$parts[0]] = $parts[1] ?? true;
    } else {
        $positionals[] = $arg;
    }
}

$output = new PrefixedOutput('docker-test: ', new TextOutput());
$code = 1;

try {
    $configPath = dirname(__DIR__) . '/.goblin.php';
    $config = new FileConfig((new ConfigFile($configPath))->data());

    $code = (new TestCommand(new ShellDocker($output), $config, $output))
        ->run(new Arguments($options, $positionals));
} catch (GoblinException $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    $code = 1;
}

exit($code);
