#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Goblin\Cli\Command\DailyCommand;
use Goblin\Cli\Command\InstallCommand;
use Goblin\Cli\Command\IssueCommand;
use Goblin\Cli\Command\MrCommand;
use Goblin\Cli\ParsedArgv;
use Goblin\Config\ConfigFile;
use Goblin\Config\FileConfig;
use Goblin\Git\ShellGit;
use Goblin\GoblinException;
use Goblin\Http\CurlHttp;
use Goblin\Http\TokenHttp;
use Goblin\Output\DebugOutput;
use Goblin\Output\JsonOutput;
use Goblin\Output\PrefixedOutput;
use Goblin\Output\TextOutput;

$parsed = new ParsedArgv($argv);
$command = $parsed->command();
$args = $parsed->arguments();

$isTty = function_exists('stream_isatty')
    ? stream_isatty(STDOUT)
    : (function_exists('posix_isatty') && posix_isatty(STDOUT));

$output = new PrefixedOutput(
    'Goblin: ',
    $isTty ? new TextOutput() : new JsonOutput(),
);

if ($args->flag('debug')) {
    $output = new DebugOutput($output);
}

if ($command === 'install') {
    try {
        $code = (new InstallCommand($output))->run($args);
    } catch (GoblinException $e) {
        fwrite(STDERR, $e->getMessage() . PHP_EOL);
        $code = 1;
    }
    exit($code);
}

$configPath = dirname(__DIR__) . '/.goblin.php';

try {
    $config = new FileConfig((new ConfigFile($configPath))->data());
    $http = new CurlHttp(
        $config->value('jira-url'),
        $config->value('jira-user'),
        $config->value('jira-token'),
    );

    $git = new ShellGit();
    $commands = [
        'issue' => new IssueCommand($http, $git, $config),
        'daily' => new DailyCommand($http, $config),
    ];

    if ($config->has('gitlab-url') && $config->has('gitlab-token')) {
        $commands['mr'] = new MrCommand(
            $git,
            new TokenHttp(
                $config->value('gitlab-url') . '/api/v4',
                'PRIVATE-TOKEN',
                $config->value('gitlab-token'),
            ),
        );
    }

    if ($command === '' || !array_key_exists($command, $commands)) {
        throw new GoblinException("Unknown command: {$command}");
    }

    $code = $commands[$command]->run($args);
} catch (GoblinException $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    $code = 1;
}

exit($code);
