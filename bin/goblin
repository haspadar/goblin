#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Goblin\Cli\BranchCheckCommand;
use Goblin\Cli\CommitCheckCommand;
use Goblin\Cli\DailyCommand;
use Goblin\Cli\IssueCommand;
use Goblin\Cli\MrCommand;
use Goblin\Cli\ParsedArgv;
use Goblin\Cli\RoutedCommand;
use Goblin\Config\ConfigFile;
use Goblin\Config\FileConfig;
use Goblin\Git\ShellGit;
use Goblin\GoblinException;
use Goblin\Http\CurlHttp;
use Goblin\Http\TokenHttp;
use Goblin\MergeRequest\GitLabMergeRequest;
use Goblin\MergeRequest\ProjectPath;

$args = (new ParsedArgv($argv))->arguments();
$configPath = dirname(__DIR__) . '/.goblin.php';

try {
    $config = new FileConfig((new ConfigFile($configPath))->data());
    $http = new CurlHttp(
        $config->value('jira-url'),
        $config->value('jira-user'),
        $config->value('jira-token'),
    );

    $git = new ShellGit();
    $gitlab = new TokenHttp(
        $config->value('gitlab-url') . '/api/v4',
        'PRIVATE-TOKEN',
        $config->value('gitlab-token'),
    );

    $code = (new RoutedCommand([
        'issue' => new IssueCommand($http, $config),
        'daily' => new DailyCommand($http, $config),
        'branch-check' => new BranchCheckCommand($git, $http, $config),
        'commit-check' => new CommitCheckCommand($config),
        'mr' => new MrCommand(
            new GitLabMergeRequest(
                $gitlab,
                (new ProjectPath($git->remote()))->value(),
            ),
        ),
    ]))->run($args);
} catch (GoblinException $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    $code = 1;
}

exit($code);
