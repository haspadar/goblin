{
    "name": "haspadar/goblin",
    "description": "CLI toolset for Jira and GitLab workflow automation",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Goblin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Goblin\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "haspadar/piqule": "dev-main"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
